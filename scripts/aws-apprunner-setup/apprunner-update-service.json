{
  "ServiceArn": "arn:aws:apprunner:eu-west-1:279127167519:service/nrcs-eam-api/62007c1a6a9c4312bec0c1b342312be1",
  "SourceConfiguration": {
    "AuthenticationConfiguration": {
      "ConnectionArn": "arn:aws:apprunner:eu-west-1:279127167519:connection/nrcs-eam-github-connection/fd859744eaaa4dcf90ced2483221fa4f"
    },
    "AutoDeploymentsEnabled": true,
    "CodeRepository": {
      "RepositoryUrl": "https://github.com/Ivano-Technologies/nrcs-eam",
      "SourceCodeVersion": {
        "Type": "BRANCH",
        "Value": "main"
      },
      "SourceDirectory": "/",
      "CodeConfiguration": {
