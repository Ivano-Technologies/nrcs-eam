{
  "installCommand": "pnpm install --no-frozen-lockfile",
  "buildCommand": "pnpm run build:frontend && pnpm exec esbuild server/_core/vercelTrpcHandler.ts --platform=node --bundle --format=cjs --outfile=api/trpc/_handler.cjs --external:canvas --external:*.node",
  "outputDirectory": "dist/public",
  "functions": {
    "api/trpc/[trpc].js": {
      "maxDuration": 60
    },
    "api/health.ts": {
      "memory": 512,
      "maxDuration": 10
    },
    "api/cron/daily.ts": {
      "memory": 512,
      "maxDuration": 30
    },
    "api/cron/weekly.ts": {
      "memory": 512,
      "maxDuration": 30
    },
    "api/cron/monthly.ts": {
      "memory": 512,
      "maxDuration": 30
    }
  },
  "crons": [
    {
      "path": "/api/cron/daily",
      "schedule": "0 2 * * *"
    },
    {
      "path": "/api/cron/weekly",
      "schedule": "0 6 * * 1"
    },
    {
      "path": "/api/cron/monthly",
      "schedule": "0 6 1 * *"
    }
  ],
  "rewrites": [
    {
      "source": "/health",
      "destination": "/api/health"
    },
    {
      "source": "/((?!api/).*)",
      "destination": "/index.html"
    }
  ],
  "headers": [
    {
      "source": "/index.html",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-cache, no-store, must-revalidate"
        }
      ]
    },
    {
      "source": "/assets/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    }
  ]
}
