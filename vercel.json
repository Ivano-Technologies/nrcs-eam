{
  "installCommand": "pnpm install --frozen-lockfile",
  "buildCommand": "pnpm run build:frontend && pnpm run build:vercel-handlers",
  "outputDirectory": "dist/public",
  "functions": {
    "api/trpc/[trpc].js": {
      "maxDuration": 60
    },
    "api/health.ts": {
      "memory": 512,
      "maxDuration": 10
    },
    "api/cron/daily.js": {
      "maxDuration": 60
    },
    "api/cron/weekly.js": {
      "maxDuration": 60
    },
    "api/cron/monthly.js": {
      "maxDuration": 60
    }
  },
  "rewrites": [
    {
      "source": "/health",
      "destination": "/api/health"
    },
    {
      "source": "/((?!api/).*)",
      "destination": "/index.html"
    }
  ],
  "headers": [
    {
      "source": "/index.html",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-cache, no-store, must-revalidate"
        }
      ]
    },
    {
      "source": "/assets/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    }
  ]
}
