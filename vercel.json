{
  "installCommand": "pnpm install --frozen-lockfile",
  "buildCommand": "pnpm run build:frontend && pnpm run build:vercel-handlers",
  "outputDirectory": "dist/public",
  "functions": {
    "api/trpc/[trpc].js": {
      "maxDuration": 60,
      "regions": ["dub1"]
    },
    "api/keep-alive.ts": {
      "maxDuration": 10,
      "regions": ["dub1"]
    },
    "api/health.ts": {
      "maxDuration": 10
    },
    "api/cron/daily.ts": {
      "maxDuration": 60,
      "regions": ["dub1"]
    },
    "api/cron/weekly.ts": {
      "maxDuration": 60,
      "regions": ["dub1"]
    },
    "api/cron/monthly.ts": {
      "maxDuration": 60,
      "regions": ["dub1"]
    },
    "api/cron/process-jobs.ts": {
      "maxDuration": 60,
      "regions": ["dub1"]
    },
    "api/cron/scheduled-reports.ts": {
      "maxDuration": 60,
      "regions": ["dub1"]
    }
  },
  "crons": [
    {
      "path": "/api/keep-alive",
      "schedule": "0 9 */5 * *"
    },
    {
      "path": "/api/cron/daily",
      "schedule": "0 2 * * *"
    },
    {
      "path": "/api/cron/weekly",
      "schedule": "0 6 * * 1"
    },
    {
      "path": "/api/cron/monthly",
      "schedule": "0 6 1 * *"
    },
    {
      "path": "/api/cron/process-jobs",
      "schedule": "0 3 * * *"
    },
    {
      "path": "/api/cron/scheduled-reports",
      "schedule": "0 7 * * *"
    }
  ],
  "rewrites": [
    {
      "source": "/health",
      "destination": "/api/health"
    },
    {
      "source": "/((?!api/).*)",
      "destination": "/index.html"
    }
  ],
  "headers": [
    {
      "source": "/index.html",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-cache, no-store, must-revalidate"
        }
      ]
    },
    {
      "source": "/assets/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    },
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "Strict-Transport-Security",
          "value": "max-age=63072000; includeSubDomains; preload"
        },
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "X-Frame-Options",
          "value": "DENY"
        },
        {
          "key": "Referrer-Policy",
          "value": "strict-origin-when-cross-origin"
        },
        {
          "key": "Permissions-Policy",
          "value": "camera=(self), geolocation=(self), microphone=()"
        },
        {
          "key": "Content-Security-Policy-Report-Only",
          "value": "default-src 'self'; script-src 'self' 'unsafe-inline' https://maps.googleapis.com https://forge.butterfly-effect.dev; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' data: https://fonts.gstatic.com; img-src 'self' data: blob: https://*.supabase.co https://maps.googleapis.com https://maps.gstatic.com https://*.googleapis.com https://*.gstatic.com https://*.posthog.com https://eu.i.posthog.com https://eu-assets.i.posthog.com https://forge.butterfly-effect.dev; connect-src 'self' https://*.supabase.co wss://*.supabase.co https://eu.i.posthog.com https://eu-assets.i.posthog.com https://*.posthog.com https://maps.googleapis.com https://*.googleapis.com https://forge.butterfly-effect.dev; media-src 'self' blob:; worker-src 'self' blob:; frame-ancestors 'none'; base-uri 'self'; form-action 'self'; object-src 'none'"
        }
      ]
    }
  ]
}
