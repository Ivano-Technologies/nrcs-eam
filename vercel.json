{
  "installCommand": "pnpm install --frozen-lockfile",
  "buildCommand": "pnpm run build:frontend && pnpm run build:vercel-handlers",
  "outputDirectory": "dist/public",
  "functions": {
    "api/trpc/[trpc].js": {
      "maxDuration": 60,
      "regions": ["dub1"]
    },
    "api/keep-alive.ts": {
      "maxDuration": 10,
      "regions": ["dub1"]
    },
    "api/health.ts": {
      "maxDuration": 10
    },
    "api/cron/daily.ts": {
      "maxDuration": 60,
      "regions": ["dub1"]
    },
    "api/cron/weekly.ts": {
      "maxDuration": 60,
      "regions": ["dub1"]
    },
    "api/cron/monthly.ts": {
      "maxDuration": 60,
      "regions": ["dub1"]
    },
    "api/cron/process-jobs.ts": {
      "maxDuration": 60,
      "regions": ["dub1"]
    },
    "api/cron/scheduled-reports.ts": {
      "maxDuration": 60,
      "regions": ["dub1"]
    },
    "api/cron/hourly-mv-refresh.ts": {
      "maxDuration": 60,
      "regions": ["dub1"]
    }
  },
  "crons": [
    {
      "path": "/api/keep-alive",
      "schedule": "0 9 */5 * *"
    },
    {
      "path": "/api/cron/daily",
      "schedule": "0 2 * * *"
    },
    {
      "path": "/api/cron/weekly",
      "schedule": "0 6 * * 1"
    },
    {
      "path": "/api/cron/monthly",
      "schedule": "0 6 1 * *"
    },
    {
      "path": "/api/cron/process-jobs",
      "schedule": "0 3 * * *"
    },
    {
      "path": "/api/cron/scheduled-reports",
      "schedule": "0 7 * * *"
    },
    {
      "path": "/api/cron/hourly-mv-refresh",
      "schedule": "0 * * * *"
    }
  ],
  "rewrites": [
    {
      "source": "/health",
      "destination": "/api/health"
    },
    {
      "source": "/((?!api/).*)",
      "destination": "/index.html"
    }
  ],
  "headers": [
    {
      "source": "/index.html",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-cache, no-store, must-revalidate"
        }
      ]
    },
    {
      "source": "/assets/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    }
  ]
}
