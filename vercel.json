{
  "installCommand": "pnpm install --no-frozen-lockfile",
  "buildCommand": "pnpm run build:frontend && pnpm exec esbuild server/_core/vercelTrpcHandler.ts --platform=node --bundle --format=cjs --outfile=api/trpc/_handler.cjs --external:canvas --external:*.node",
  "outputDirectory": "dist/public",
  "functions": {
    "api/trpc/[trpc].js": {
      "memory": 1024,
      "maxDuration": 30
    },
    "api/health.ts": {
      "memory": 512,
      "maxDuration": 10
    }
  },
  "rewrites": [
    {
      "source": "/health",
      "destination": "/api/health"
    },
    {
      "source": "/((?!api/).*)",
      "destination": "/index.html"
    }
  ],
  "headers": [
    {
      "source": "/index.html",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-cache, no-store, must-revalidate"
        }
      ]
    }
  ]
}
