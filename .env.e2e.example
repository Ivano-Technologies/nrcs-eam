# Copy to .env.e2e (never commit .env.e2e).
# Use local MySQL + Mailpit — do not point at production RDS.
#
#   copy .env.e2e.example .env.e2e
#   # merge any keys you need from .env (except DATABASE_URL) manually if required

DATABASE_URL=mysql://e2e:e2epass@127.0.0.1:3306/nrcs_eam_e2e

SMTP_HOST=127.0.0.1
SMTP_PORT=1025
MAILPIT_SMTP_HOST=127.0.0.1
MAILPIT_SMTP_PORT=1025
SMTP_FROM=noreply@nrcs-eam.test

NODE_ENV=development
PORT=3000

# Frontend: use same-origin API for E2E (empty VITE_API_BASE_URL → /api/trpc on this host).
VITE_APP_ID=nrcs-eam
VITE_APP_URL=http://127.0.0.1:3000
VITE_API_BASE_URL=
VITE_OAUTH_PORTAL_URL=https://oauth.manus.im

# Add other keys from .env as needed (API keys, etc.) — avoid RDS hostnames.

# Required for Playwright E2E auth bootstrap.
SUPABASE_TEST_SCHEMA=test
E2E_USER_EMAIL=playwright_admin@nrcseam.techivano.com
E2E_USER_PASSWORD=PlaywrightTest@2026
