  "scripts": {
    "dev": "cross-env NODE_ENV=development tsx watch server/_core/index.ts",
    "build": "node scripts/fetch-rds-ca.mjs && vite build && esbuild server/_core/index.ts --platform=node --packages=external --bundle --format=esm --outfile=dist/index.js",
    "build:frontend": "vite build",
    "build:vercel-handlers": "node scripts/build-vercel-handlers.mjs",
    "deploy:frontend": "powershell -ExecutionPolicy Bypass -File ./scripts/deploy-frontend.ps1",
    "start": "cross-env NODE_ENV=production node dist/index.js",
    "start:prod": "node dist/index.js",
    "check": "tsc --noEmit",
    "check:full": "node scripts/check/run-all.mjs",
    "format": "prettier --write .",
    "test": "tsx scripts/db/seed-db.mjs && vitest run",
    "db:push": "drizzle-kit generate && drizzle-kit migrate",
    "db:migrate:dev": "dotenv -e .env -- drizzle-kit migrate",
    "db:migrate:e2e": "dotenv -e .env.e2e -- drizzle-kit migrate",
    "db:reset": "node scripts/db/reset-db.mjs",
    "db:check": "tsx scripts/db-check.ts",
    "db:check:e2e": "dotenv -e .env.e2e -- tsx scripts/db-check.ts",
    "db:seed": "node scripts/db/seed-db.mjs",
    "db:seed:e2e": "dotenv -e .env.e2e -- node scripts/db/seed-db.mjs",
    "seed-e2e:local": "dotenv -e .env.e2e -- tsx scripts/db/seed-e2e.ts",
    "db:seed:sample": "node scripts/db/seed-sample-data.mjs",
    "db:seed:wms-donors": "tsx scripts/db/seed-wms-donors.ts",
    "db:cleanup": "node scripts/db/cleanup-database.mjs",
    "db:clean-test-data": "tsx scripts/db/clean-test-data.ts",
    "db:full-reset": "tsx scripts/db/full-reset.ts",
    "db:seed-reference": "tsx scripts/db/seed-reference-data.ts",
    "db:seed-facilities": "tsx scripts/db/seed-facilities.ts",
    "db:audit:catalogue-wms": "tsx scripts/db/audit-inventory-catalogue-wms.ts",
    "db:apply:ifrc-audit": "tsx scripts/db/apply-ifrc-catalogue-audit.ts",
    "db:import:ifrc": "tsx scripts/db/import-ifrc-catalogue.ts",
    "db:backfill-facility-types": "tsx scripts/db/backfill-facility-types.ts",
    "pwa:icons": "node scripts/pwa/generate-pwa-icons.mjs",
    "test:pdfkit": "tsx scripts/pdfkit-smoke.ts",
    "test:resend": "tsx scripts/test-resend.ts",
    "dev:e2e": "dotenv -e .env.e2e -- cross-env NODE_ENV=development SUPABASE_TEST_SCHEMA=test tsx server/_core/index.ts",
    "mailpit": "C:\\Antigravity\\Tools\\mailpit\\mailpit.exe --smtp 127.0.0.1:1025 --listen 127.0.0.1:8025",
    "test:e2e": "cross-env CI=true DISABLE_VITE_JSX_LOC=1 playwright test",
    "test:e2e:headed": "playwright test --headed",
    "swap": "node scripts/swap.mjs"
  },
