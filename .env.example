# -----------------------------------------------------------------------------
# Frontend (Vite) — optional; no secrets. Values are baked in at `vite build` time.
# Use .env.local for local dev. In CI/S3 deploy, set these in the build environment.
# -----------------------------------------------------------------------------
# Production split hosting (CloudFront SPA + App Runner API), no trailing slash:
# VITE_API_BASE_URL=https://api.nrcseam.techivano.com
# Leave empty for same-origin /api/trpc (monolith or reverse proxy).
VITE_API_BASE_URL=

# Optional Umami (or compatible) analytics — both required to load the tracker script.
# Endpoint = base URL only (no /umami suffix). Example: https://analytics.example.com
VITE_ANALYTICS_ENDPOINT=
VITE_ANALYTICS_WEBSITE_ID=

# Database (PostgreSQL — Drizzle + postgres.js; Supabase example below)
# Local: omit DATABASE_SSL or set false.
# Supabase: postgresql://postgres.[PROJECT]:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:6543/postgres
# URL-encode special characters in the password.
DATABASE_URL=postgresql://postgres:password@127.0.0.1:5432/postgres
DATABASE_SSL=false
# With DATABASE_SSL=true: Node may not trust the RDS chain without AWS CA bundle.
# Omit or set false (default) to allow TLS without verifying the chain (typical for dev/RDS).
# Set true only with DATABASE_SSL_CA_PATH + global-bundle.pem (production).
DATABASE_SSL_REJECT_UNAUTHORIZED=false
# Path to AWS RDS global-bundle.pem (relative to process cwd or absolute). See certs/README.md.
# DATABASE_SSL_CA_PATH=./certs/global-bundle.pem

# CORS — comma-separated HTTPS origins for browser clients (SPA). No wildcards.
# Non-production: localhost:3000 and :5173 are always allowed in addition to this list.
# Split hosting example: CORS_ORIGINS=https://nrcseam.techivano.com
CORS_ORIGINS=

# Public SPA origin (no trailing slash): OAuth post-login redirect and magic-link emails
# (`/auth/verify?...`). On App Runner, prefer this over VITE_APP_URL (Vite vars may be unset).
# Example: FRONTEND_ORIGIN=https://nrcseam.techivano.com
FRONTEND_ORIGIN=

# Optional: session cookie Domain for sibling subdomains (e.g. api.* + nrcseam.*). Use leading dot.
# Example: SESSION_COOKIE_DOMAIN=.techivano.com
# SESSION_COOKIE_DOMAIN=

# Session / JWT signing (required for auth cookies)
JWT_SECRET=change-me-to-a-long-random-string

# App identity (used by OAuth portal flow if enabled)
VITE_APP_ID=
VITE_OAUTH_PORTAL_URL=

# Owner bootstrap (optional)
OWNER_OPEN_ID=
OWNER_NAME=

# Optional: object storage for uploads
S3_BUCKET=
S3_REGION=
S3_ACCESS_KEY=
S3_SECRET_KEY=

# Optional: Manus / Forge APIs
BUILT_IN_FORGE_API_URL=
BUILT_IN_FORGE_API_KEY=

# AWS Secrets Manager (production / App Runner / ECS — optional)
# If unset, local dev uses only this file + shell env. If set, startup merges JSON from SM into process.env.
# AWS_SECRETS_SECRET_ID=nrcs-eam/prod/app
# AWS_REGION=eu-west-1
