# -----------------------------------------------------------------------------
# Frontend (Vite) — baked in at `vite build` (set in Vercel **Build** environment).
# -----------------------------------------------------------------------------
# **Vercel SPA (static):** set `VITE_API_BASE_URL` to your **API** origin (HTTPS, no trailing slash),
# e.g. `https://api.example.com` or your Node host. Otherwise the browser calls same-origin `/api/trpc`,
# which only works when the Express API is served from the same host as the SPA.
# VITE_API_BASE_URL=https://your-api.example.com

# Public Supabase values (match server `SUPABASE_URL` and `SUPABASE_ANON_KEY`). Optional if all auth is via tRPC.
# VITE_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
# VITE_SUPABASE_ANON_KEY=

# Optional analytics
# VITE_ANALYTICS_ENDPOINT=
# VITE_ANALYTICS_WEBSITE_ID=

# -----------------------------------------------------------------------------
# Server / Drizzle — use Supabase PostgreSQL (not AWS RDS).
# -----------------------------------------------------------------------------
# **Supabase pooler (recommended for serverless / pooled):**
# postgresql://postgres.[PROJECT-REF]:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:6543/postgres
# **Direct (session mode):** port 5432 on `db.[PROJECT-REF].supabase.co`
# URL-encode special characters in the password. Host must contain `supabase.co` for hosted Supabase.
DATABASE_URL=postgresql://postgres:password@127.0.0.1:5432/postgres

# TLS: Supabase pooler uses TLS; for local Postgres often false.
DATABASE_SSL=false
DATABASE_SSL_REJECT_UNAUTHORIZED=false
# Optional: only if you pin a custom CA (not typical for Supabase).
# DATABASE_SSL_CA_PATH=

# CORS — comma-separated HTTPS origins for browser clients (your Vercel SPA origin(s)).
# Example: CORS_ORIGINS=https://nrcseam.techivano.com
CORS_ORIGINS=

# Public SPA origin (no trailing slash): magic-link `emailRedirectTo` and cookie `SameSite` alignment.
# Example: FRONTEND_ORIGIN=https://nrcseam.techivano.com
FRONTEND_ORIGIN=

# Optional: session cookie Domain for sibling subdomains (leading dot).
# SESSION_COOKIE_DOMAIN=

# -----------------------------------------------------------------------------
# Supabase Auth (server — required in production for API process / Vercel serverless if used)
# -----------------------------------------------------------------------------
SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
# Required for local E2E seed/auth bootstrap (`.env.e2e`).
# TEST_USER_PASSWORD=

# Optional legacy — unused by Supabase cookie sessions
# JWT_SECRET=

# Optional app identity (legacy)
# VITE_APP_ID=
# VITE_OAUTH_PORTAL_URL=

# Owner bootstrap (optional)
# OWNER_OPEN_ID=
# OWNER_NAME=

# Optional: S3 for uploads
# S3_BUCKET=
# S3_REGION=
# S3_ACCESS_KEY=
# S3_SECRET_KEY=

# Optional: Manus / Forge APIs
# BUILT_IN_FORGE_API_URL=
# BUILT_IN_FORGE_API_KEY=

# Optional: AWS Secrets Manager (merges JSON into process.env at startup)
# AWS_SECRETS_SECRET_ID=
# AWS_REGION=
