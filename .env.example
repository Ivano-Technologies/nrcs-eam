# Database (MySQL — connection string for Drizzle + mysql2)
# Local: omit DATABASE_SSL or set false.
# AWS RDS: set DATABASE_SSL=true (TLS). URL-encode special characters in the password.
DATABASE_URL=mysql://user:password@127.0.0.1:3306/nrcs_eam
DATABASE_SSL=false
# With DATABASE_SSL=true: Node may not trust the RDS chain without AWS CA bundle.
# Omit or set false (default) to allow TLS without verifying the chain (typical for dev/RDS).
# Set true only with DATABASE_SSL_CA_PATH + global-bundle.pem (production).
DATABASE_SSL_REJECT_UNAUTHORIZED=false

# Session / JWT signing (required for auth cookies)
JWT_SECRET=change-me-to-a-long-random-string

# App identity (used by OAuth portal flow if enabled)
VITE_APP_ID=
VITE_OAUTH_PORTAL_URL=

# Owner bootstrap (optional)
OWNER_OPEN_ID=
OWNER_NAME=

# Optional: object storage for uploads
S3_BUCKET=
S3_REGION=
S3_ACCESS_KEY=
S3_SECRET_KEY=

# Optional: Manus / Forge APIs
BUILT_IN_FORGE_API_URL=
BUILT_IN_FORGE_API_KEY=

# AWS Secrets Manager (production / App Runner / ECS — optional)
# If unset, local dev uses only this file + shell env. If set, startup merges JSON from SM into process.env.
# AWS_SECRETS_SECRET_ID=nrcs-eam/prod/app
# AWS_REGION=eu-west-1
